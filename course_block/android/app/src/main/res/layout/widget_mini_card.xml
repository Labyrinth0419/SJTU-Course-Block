<?xml version="1.0" encoding="utf-8"?>
<!-- 紧凑课程卡片：供 addView() 近日/一周课程小组件的列中使用 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="3dp"
    android:paddingBottom="3dp"
    android:paddingEnd="2dp"
    android:gravity="center_vertical">

    <!-- 左侧彩色强调条（颜色由 Provider 动态设置） -->
    <TextView
        android:id="@+id/mini_bar"
        android:layout_width="3dp"
        android:layout_height="32dp"
        android:background="@drawable/widget_course_bar"
        android:layout_marginEnd="5dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- 课程名 -->
        <TextView
            android:id="@+id/mini_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="--"
            android:textColor="@color/widget_course_title"
            android:textSize="10sp"
            android:textStyle="bold" />

        <!-- 地点 + 时间 -->
        <TextView
            android:id="@+id/mini_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text=""
            android:textColor="@color/widget_course_detail"
            android:textSize="9sp" />

    </LinearLayout>
</LinearLayout>