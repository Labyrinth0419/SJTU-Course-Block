<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_today_bg"
    android:orientation="vertical"
    android:paddingLeft="10dp"
    android:paddingRight="10dp"
    android:paddingTop="6dp"
    android:paddingBottom="8dp"
>

    <!-- 紧凑头部：课表名 · 周次日期（单行，刷新移至左下角） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
    >

        <TextView
            android:id="@+id/tv_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="今日课程"
            android:textColor="@color/widget_header_text"
            android:textSize="12sp"
            android:textStyle="bold"
        />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="3.11  第1周  Wed"
            android:textColor="@color/widget_subtitle_text"
            android:textSize="10sp"
        />

    </LinearLayout>

    <!-- 分割线（TextView 替代 View，避免 Vivo OriginOS inflate 失败）-->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="3dp"
        android:background="@color/widget_divider"
    />

    <!-- 可滚动课程列表（填满剩余空间，支持上下拨动） -->
    <ListView
        android:id="@+id/widget_list_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:scrollbars="none"
    />

    <!-- 空状态（adapter 为空时由 setEmptyView 自动显示） -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="今日暂无课程 ☀"
        android:textColor="@color/widget_empty_text"
        android:textSize="12sp"
        android:visibility="gone"
    />

    <!-- 底部分割线 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="4dp"
        android:background="@color/widget_divider"
    />

    <!-- 底部操作行：刷新（左）+ 打开应用（右） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
    >

        <TextView
            android:id="@+id/btn_refresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↻"
            android:textColor="@color/widget_accent"
            android:textSize="14sp"
        />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
        />

        <TextView
            android:id="@+id/btn_open"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="打开 →"
            android:textColor="@color/widget_open_btn"
            android:textSize="11sp"
        />

    </LinearLayout>

</LinearLayout>